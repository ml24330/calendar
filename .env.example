# Copy to .env and fill in. .env is gitignored — never commit real values.
#
#   turso db show <your-db> --url
#   turso db tokens create <your-db>
#
# Used by `npm run dev-live-db`, which points local development at the same
# database production uses. `npm run dev` ignores this file entirely and works
# against a local calendar.db.

TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=

# Only needed if you want the local server to claim the calendar itself.
# ADMIN_PASSPHRASE=
